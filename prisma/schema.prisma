generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id              String              @id @default(cuid())
  name            String              @unique
  domain          String?             @unique
  logo            String?
  plan            String              @default("BASIC")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  status          CompanyStatus       @default(ACTIVE)
  empIdPrefix     String              @default("EMP-")
  nextEmpNumber   Int                 @default(1001)
  address         String?
  contactEmail    String?
  contactPhone    String?
  subscriptionEnd DateTime?
  trialEndsAt     DateTime?
  categories      Category[]
  clients         Client[]
  invitations     CompanyInvitation[]
  departments     Department[]
  designations    Designation[]
  employees       Employee[]
  leads           Lead[]
  statuses        LeadStatus[]
  products        Product[]
  quotations      Quotation[]
  users           User[]
}

model Client {
  id               String          @id @default(cuid())
  companyId        String
  name             String
  domain           String?
  phone            String?
  email            String?
  address          String?
  natureOfBusiness String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  company          Company         @relation(fields: [companyId], references: [id])
  contacts         ClientContact[]
  leads            Lead[]

  @@unique([name, companyId])
  @@index([companyId])
}

model ClientContact {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  email       String?
  phone       String?
  designation String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model User {
  id                String              @id @default(cuid())
  clerkId           String?             @unique
  email             String              @unique
  name              String?
  role              Role                @default(SALES_EXECUTIVE)
  companyId         String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  departmentId      String?
  designationId     String?
  managerId         String?
  status            UserStatus          @default(ACTIVE)
  isSystemAdmin     Boolean             @default(false)
  imageUrl          String?
  employeeId        String?             @unique
  invitations       CompanyInvitation[] @relation("UserToInvitation")
  assignedLeads     Lead[]              @relation("LeadAssignedTo")
  ownedLeads        Lead[]              @relation("LeadOwner")
  activities        LeadActivity[]
  followUps         LeadFollowUp[]
  createdQuotations Quotation[]         @relation("QuotationCreator")
  tasks             Task[]
  company           Company             @relation(fields: [companyId], references: [id])
  department        Department?         @relation(fields: [departmentId], references: [id])
  designation       Designation?        @relation(fields: [designationId], references: [id])
  employee          Employee?           @relation(fields: [employeeId], references: [id])
  manager           User?               @relation("ReportsTo", fields: [managerId], references: [id])
  subordinates      User[]              @relation("ReportsTo")
  collaboratingOn   Lead[]              @relation("LeadCollaborators")
  closedLeads       Lead[]              @relation("LeadClosedBy")
}

model Employee {
  id                 String       @id @default(cuid())
  employeeId         String       @unique
  firstName          String
  lastName           String
  email              String       @unique
  phone              String
  status             String       @default("ACTIVE")
  companyId          String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  altPhone           String?
  city               String?
  country            String       @default("United Arab Emirates")
  departmentId       String
  designationId      String
  reportingToId      String?
  role               EmployeeRole @default(STAFF)
  imageUrl           String?
  fullAddress        String?
  joiningDate        DateTime?    @default(now())
  probationDays      Int          @default(90)
  bankName           String?
  dob                DateTime?
  emergencyName      String?
  emergencyPhone     String?
  iban               String?
  swiftCode          String?
  gender             String?
  attachments        Attachment[]
  managedDepartments Department[] @relation("DepartmentManager")
  company            Company      @relation(fields: [companyId], references: [id])
  department         Department   @relation("EmployeeToDepartment", fields: [departmentId], references: [id])
  designation        Designation  @relation(fields: [designationId], references: [id])
  reportingTo        Employee?    @relation("Hierarchy", fields: [reportingToId], references: [id])
  subordinates       Employee[]   @relation("Hierarchy")
  user               User?

  @@index([companyId])
  @@index([departmentId])
}

model Lead {
  companyId        String
  clientCompany    String?
  clientName       String?
  ownerId          String?
  id               String         @id @default(cuid())
  name             String
  email            String
  phone            String?
  value            Float          @default(0)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  statusId         String?
  designation      String?
  assignedToId     String?
  closedById       String?
  followUpNotes    String?
  nextFollowUp     DateTime?
  address          String?
  brand            String?
  location         String?
  source           String?
  categoryId       String?
  startDate        DateTime       @default(now())
  isEnquiry        Boolean        @default(true)
  lossReason       String?
  natureOfBusiness String?
  clientId         String?
  attachments      Attachment[]
  assignedTo       User?          @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  category         Category?      @relation(fields: [categoryId], references: [id])
  client           Client?        @relation(fields: [clientId], references: [id])
  company          Company        @relation(fields: [companyId], references: [id])
  owner            User?          @relation("LeadOwner", fields: [ownerId], references: [id])
  status           LeadStatus?    @relation(fields: [statusId], references: [id])
  activities       LeadActivity[]
  followUps        LeadFollowUp[]
  quotations       Quotation[]
  tasks            Task[]
  collaborators    User[]         @relation("LeadCollaborators")
  products         Product[]      @relation("LeadProducts")
  closedBy         User?          @relation("LeadClosedBy", fields: [closedById], references: [id])

  @@index([companyId])
  @@index([statusId])
}

model LeadFollowUp {
  id          String    @id @default(cuid())
  leadId      String
  userId      String
  scheduledAt DateTime
  notes       String?
  isDone      Boolean   @default(false)
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([userId])
  @@index([scheduledAt])
}

model Task {
  id          String   @id @default(cuid())
  content     String
  priority    String   @default("NORMAL")
  board       String   @default("TODAY")
  order       Int      @default(0)
  isCompleted Boolean  @default(false)
  userId      String
  leadId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lead        Lead?    @relation(fields: [leadId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Department {
  id        String       @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  managerId String?
  parentId  String?
  company   Company      @relation(fields: [companyId], references: [id])
  manager   Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  parent    Department?  @relation("SubDepartments", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Department[] @relation("SubDepartments")
  employees Employee[]   @relation("EmployeeToDepartment")
  users     User[]
}

model Designation {
  id           String     @id @default(cuid())
  name         String
  companyId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  isManagement Boolean    @default(false)
  company      Company    @relation(fields: [companyId], references: [id])
  employees    Employee[]
  users        User[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime  @default(now())
  company   Company   @relation(fields: [companyId], references: [id])
  leads     Lead[]
  products  Product[]

  @@unique([name, companyId])
  @@index([companyId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float    @default(0)
  unit        String   @default("pcs")
  categoryId  String
  companyId   String
  createdAt   DateTime @default(now())
  category    Category @relation(fields: [categoryId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])
  leads       Lead[]   @relation("LeadProducts")

  @@index([categoryId])
  @@index([companyId])
}

model LeadStatus {
  id        String   @id @default(cuid())
  label     String
  color     String   @default("#3b82f6")
  order     Int      @default(0)
  isClosing Boolean  @default(false)
  isWon     Boolean  @default(false)
  companyId String
  createdAt DateTime @default(now())
  leads     Lead[]
  company   Company  @relation(fields: [companyId], references: [id])
}

model LeadActivity {
  id        String   @id @default(cuid())
  type      String
  content   String
  remarks   String?
  leadId    String
  userId    String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Attachment {
  id         String    @id @default(cuid())
  name       String
  url        String
  size       Int?
  type       String?
  leadId     String
  createdAt  DateTime  @default(now())
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model CompanyInvitation {
  id            String   @id @default(cuid())
  email         String
  name          String
  role          Role     @default(ADMIN)
  status        String   @default("PENDING")
  companyId     String
  invitedBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  invitedByUser User     @relation("UserToInvitation", fields: [invitedBy], references: [id])

  @@unique([email, companyId])
}

model Quotation {
  id          String          @id @default(cuid())
  qId         String          @unique
  status      String          @default("DRAFT")
  version     Int             @default(1)
  subTotal    Float
  taxAmount   Float           @default(0)
  discount    Float           @default(0)
  totalAmount Float
  leadId      String
  createdById String
  companyId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  company     Company         @relation(fields: [companyId], references: [id])
  createdBy   User            @relation("QuotationCreator", fields: [createdById], references: [id])
  lead        Lead            @relation(fields: [leadId], references: [id])
  items       QuotationItem[]
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Float
  unitPrice   Float
  total       Float
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  TRIAL
}

enum EmployeeRole {
  STAFF
  SUPERVISOR
  MANAGER
  HR
  ADMIN
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES_EXECUTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}
